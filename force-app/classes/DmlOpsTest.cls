@IsTest
public with sharing class DmlOpsTest {
    @IsTest
    static void testCreateLog() {
        List<Account> accounts = new List<Account>();
        Account a = new Account();
        accounts.add(a);

        Test.startTest();
        DmlOps.create(accounts);
        Test.stopTest();

        List<Log__c> logs = getLogsWithEntries();

        Assert.areEqual(1, logs.size(), 'There should be 1 Log record');
        Assert.areEqual(1, logs[0].LogEntries__r.size(), 'There should be 1 Log Entry record');

        Assert.areEqual('DML: Account', logs[0].TransactionScenarioText__c, 'The Log Scenario should have been autogenerated on the Log__c');
        Assert.areEqual('DML: Account', logs[0].LogEntries__r[0].EntryScenarioText__c, 'The Entry Scenario should have been autogenerated on the LogEntry__c');
        Assert.areEqual('Failed to Insert Account record.', logs[0].LogEntries__r[0].Message__c, 'The correct Message should have been set on the LogEntry__c');
        Assert.areEqual('ERROR', logs[0].LogEntries__r[0].LoggingLevel__c, 'The Logging Level should be ERROR');
        Assert.areEqual('Database.SaveResult', logs[0].LogEntries__r[0].DatabaseResultType__c, 'The Database Result Type should be Database.SaveResult');
        Assert.isTrue(logs[0].LogEntries__r[0].DatabaseResultJson__c.contains('Required fields are missing: [Name]'), 'The Database Result should contain the error');
    }

    @IsTest
    static void testModifyLog() {
        Account account = new Account();
        account.Name = 'Test';
        insert account;

        account.Name = '';

        List<Account> accounts = new List<Account>();
        accounts.add(account);

        Test.startTest();
        DmlOps.modify(accounts);
        Test.stopTest();

        List<Log__c> logs = getLogsWithEntries();

        Assert.areEqual(1, logs.size(), 'There should be 1 Log record');
        Assert.areEqual(1, logs[0].LogEntries__r.size(), 'There should be 1 Log Entry record');

        Assert.areEqual('DML: Account', logs[0].TransactionScenarioText__c, 'The Log Scenario should have been autogenerated on the Log__c');
        Assert.areEqual('DML: Account', logs[0].LogEntries__r[0].EntryScenarioText__c, 'The Entry Scenario should have been autogenerated on the LogEntry__c');
        Assert.areEqual('Failed to Update Account record.', logs[0].LogEntries__r[0].Message__c, 'The correct Message should have been set on the LogEntry__c');
        Assert.areEqual('ERROR', logs[0].LogEntries__r[0].LoggingLevel__c, 'The Logging Level should be ERROR');
        Assert.areEqual('Database.SaveResult', logs[0].LogEntries__r[0].DatabaseResultType__c, 'The Database Result Type should be Database.SaveResult');
        Assert.isTrue(logs[0].LogEntries__r[0].DatabaseResultJson__c.contains('Required fields are missing: [Name]'), 'The Database Result should contain the error');
    }

    @IsTest
    static void testNullHandled() {
        List<Account> accounts;

        Test.startTest();
        DmlOps.create(accounts);
        Test.stopTest();

        List<Log__c> logs = getLogsWithEntries();

        Assert.areEqual(1, logs.size(), 'There should be 1 Log record');
        Assert.areEqual(1, logs[0].LogEntries__r.size(), 'There should be 1 Log Entry record');

        Assert.areEqual('DML: Unknown', logs[0].TransactionScenarioText__c, 'The Log Scenario should \'DML: Unknown\' - as unable to infer when list is null');
        Assert.areEqual('DML: Unknown', logs[0].LogEntries__r[0].EntryScenarioText__c, 'The Entry Scenario should \'DML: Unknown\' - as unable to infer when list is null');
        Assert.areEqual('DmlOps.create() called with null list of records', logs[0].LogEntries__r[0].Message__c, 'The correct Message should have been set on the LogEntry__c');
        Assert.areEqual('ERROR', logs[0].LogEntries__r[0].LoggingLevel__c, 'The Logging Level should be ERROR');
    }

    @IsTest
    static void testEmptyHandled() {
        List<Account> accounts = new List<Account>();

        Test.startTest();
        DmlOps.create(accounts);
        Test.stopTest();

        List<Log__c> logs = getLogsWithEntries();

        Assert.areEqual(1, logs.size(), 'There should be 1 Log record');
        Assert.areEqual(1, logs[0].LogEntries__r.size(), 'There should be 1 Log Entry record');

        Assert.areEqual('DML: Unknown', logs[0].TransactionScenarioText__c, 'The Log Scenario should \'DML: Unknown\' - as unable to infer when list is empty');
        Assert.areEqual('DML: Unknown', logs[0].LogEntries__r[0].EntryScenarioText__c, 'The Entry Scenario should \'DML: Unknown\' - as unable to infer when list is empty');
        Assert.areEqual('DmlOps.create() called with empty list of records', logs[0].LogEntries__r[0].Message__c, 'The correct Message should have been set on the LogEntry__c');
        Assert.areEqual('ERROR', logs[0].LogEntries__r[0].LoggingLevel__c, 'The Logging Level should be ERROR');
    }

    @IsTest
    static void testWithOptions() {
        List<Account> accounts = new List<Account>();
        Account a = new Account();
        accounts.add(a);

        DmlOps.Options options = new DmlOps.Options();
        options.loggingScenario = 'Test Scenario';

        Test.startTest();
        DmlOps.create(accounts, options);
        Test.stopTest();

        List<Log__c> logs = getLogsWithEntries();

        Assert.areEqual(1, logs.size(), 'There should be 1 Log record');
        Assert.areEqual(1, logs[0].LogEntries__r.size(), 'There should be 1 Log Entry record');

        Assert.areEqual('Test Scenario', logs[0].TransactionScenarioText__c, 'The Log Scenario should have been set based on the DmlOps.Options');
        Assert.areEqual('Test Scenario', logs[0].LogEntries__r[0].EntryScenarioText__c, 'The Entry Scenario should have been autogenerated on the LogEntry__c');
    }

    @IsTest
    static void testWithOptionsAsMap() {
        List<Account> accounts = new List<Account>();
        Account a = new Account();
        accounts.add(a);

        Test.startTest();
        DmlOps.create(accounts, new DmlOps.Options(new Map<String, Object>{ 'loggingScenario' => 'Test Scenario' }));
        Test.stopTest();

        List<Log__c> logs = getLogsWithEntries();

        Assert.areEqual(1, logs.size(), 'There should be 1 Log record');
        Assert.areEqual(1, logs[0].LogEntries__r.size(), 'There should be 1 Log Entry record');

        Assert.areEqual('Test Scenario', logs[0].TransactionScenarioText__c, 'The Log Scenario should have been set based on the DmlOps.Options');
        Assert.areEqual('Test Scenario', logs[0].LogEntries__r[0].EntryScenarioText__c, 'The Entry Scenario should have been autogenerated on the LogEntry__c');
    }

    @IsTest
    static void testWithOptionsAsJson() {
        List<Account> accounts = new List<Account>();
        Account a = new Account();
        accounts.add(a);

        Test.startTest();
        DmlOps.create(accounts, new DmlOps.Options('{"loggingScenario": "Test Scenario"}'));
        Test.stopTest();

        List<Log__c> logs = getLogsWithEntries();

        Assert.areEqual(1, logs.size(), 'There should be 1 Log record');
        Assert.areEqual(1, logs[0].LogEntries__r.size(), 'There should be 1 Log Entry record');

        Assert.areEqual('Test Scenario', logs[0].TransactionScenarioText__c, 'The Log Scenario should have been set based on the DmlOps.Options');
        Assert.areEqual('Test Scenario', logs[0].LogEntries__r[0].EntryScenarioText__c, 'The Entry Scenario should have been autogenerated on the LogEntry__c');
    }

    private static List<Log__c> getLogsWithEntries() {
        return [
            SELECT
                Id,
                TransactionScenarioText__c,
                (
                    SELECT Id, EntryScenarioText__c, Message__c, LoggingLevel__c, DatabaseResultType__c, DatabaseResultJson__c
                    FROM LogEntries__r
                    WHERE LoggingLevel__c != 'FINEST' // Exclude Nebulas own logs
                )
            FROM Log__c
        ];
    }
}
